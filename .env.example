# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_admin_telegram_id_here
SUPPORT_USERNAME=your_support_username
BOT_USERNAME=your_bot_username

# Database Configuration
DATABASE_URL=postgresql+asyncpg://vpn_user:vpn_password@postgres:5432/vpn_bot_dev
ALEMBIC_URL=postgresql+asyncpg://vpn_user:vpn_password@postgres:5432/vpn_bot_dev
INIT_DB=true

# Marzban API Configuration
MARZBAN_URL=https://your-marzban-domain.com
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=your_marzban_password

# CryptoBot Configuration
CRYPTOBOT_TOKEN=your_cryptobot_api_token
CRYPTOBOT_URL=https://pay.crypt.bot/api

# Payment Configuration
# Базовые цены (используются как fallback)
SUBSCRIPTION_PRICES={"1_month": 10.0, "3_months": 25.0, "6_months": 45.0, "1_year": 80.0}

# Отдельные цены для каждого способа оплаты (в USD)
# Цены для USDT
USDT_PRICES={"1_month": 10.0, "3_months": 25.0, "6_months": 45.0, "1_year": 80.0}

# Цены для TON  
TON_PRICES={"1_month": 10.0, "3_months": 25.0, "6_months": 45.0, "1_year": 80.0}

# Цены для Telegram Stars (в звездах)
STARS_PRICES={"1_month": 50, "3_months": 135, "6_months": 250, "1_year": 450}

# Формат 2: Простой формат (ключ=значение через запятую)
# USDT_PRICES=1_month=10.0,3_months=25.0,6_months=45.0,1_year=80.0
# TON_PRICES=1_month=10.0,3_months=25.0,6_months=45.0,1_year=80.0  
# STARS_PRICES=1_month=50,3_months=135,6_months=250,1_year=450

# Формат 3: Отдельные переменные для каждой подписки
# USDT_1_MONTH=10.0
# USDT_3_MONTHS=25.0
# USDT_6_MONTHS=45.0
# USDT_1_YEAR=80.0

# Notification Settings
EXPIRY_NOTIFICATION_DAYS=3,1


# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Security
SECRET_KEY=your-secret-key-here
